# ============================================================
# VELTRIX COLLECTIVE — ENVIRONMENT VARIABLES
# Copy this to .env.local for local dev
# All production values go in Vercel environment variables
# ============================================================

# Supabase (get from Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-...

# OpenRouter (for LLM Tester tool — non-Claude models)
OPENROUTER_API_KEY=sk-or-...

# Brevo (email)
BREVO_API_KEY=your-brevo-api-key

# Lemon Squeezy (payments)
LEMON_SQUEEZY_API_KEY=your-lemon-squeezy-key
LEMON_SQUEEZY_STORE_ID=your-store-id
LEMON_SQUEEZY_WEBHOOK_SECRET=your-webhook-secret
# Full checkout URL for the Insider Access product
NEXT_PUBLIC_LEMON_SQUEEZY_CHECKOUT_URL=https://veltrix.lemonsqueezy.com/checkout/buy/...

# Discord
DISCORD_INVITE_URL=https://discord.gg/your-invite

# App
NEXT_PUBLIC_BASE_URL=https://www.veltrixcollective.com
